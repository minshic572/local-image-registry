# Harbor release and public address.
HARBOR_VERSION=2.15.1
HARBOR_HOSTNAME=harbor.local
HARBOR_SCHEME=http

# Harbor starts on the staging port while registry:2 still owns port 5001.
# The cutover command moves Harbor to HARBOR_FINAL_PORT after migration.
HARBOR_STAGING_PORT=5002
HARBOR_FINAL_PORT=5001

# Projects are public for backwards-compatible anonymous pulls. Pushes require
# the robot account created by `make harbor-init`.
HARBOR_PROJECTS="library cilium cyber-resilience"
HARBOR_PUBLIC_PROJECTS=true

# Runtime files and image data are intentionally outside version control.
# Relative paths are resolved from the repository root.
HARBOR_RUNTIME_DIR=.harbor
HARBOR_DATA_DIR=.harbor/data
HARBOR_LOG_DIR=.harbor/log
HARBOR_COMPOSE_PROJECT=local-image-registry

# Existing registry:2 instance used as the migration source.
LEGACY_REGISTRY_CONTAINER=local-image-registry
LEGACY_REGISTRY_HOST=localhost:5001

# Set true only for this isolated local Docker Desktop environment.
HARBOR_INSECURE=true
